# Nyika AI environment example. Do not commit real secrets.

# Frontend
VITE_NYIKA_API_URL=http://127.0.0.1:8787

# Backend
NYIKA_API_PORT=8787
NYIKA_API_HOST=127.0.0.1
NYIKA_ALLOWED_ORIGIN=http://127.0.0.1:5173
NYIKA_DATA_DIR=./backend/storage

# PostgreSQL login/accounts
DATABASE_URL=postgres://username:password@localhost:5432/nyika_ai
PGSSLMODE=disable
NYIKA_SESSION_DAYS=7

# Future booking/payment integrations
HOTEL_AVAILABILITY_API_KEY=
TAXI_PARTNER_API_KEY=
FLIGHT_BOOKING_API_KEY=
PAYMENT_PROVIDER_SECRET=
